---
import Base from "@layouts/base.astro"
import Pfp from "@components/pfp.astro"
import Spinner from "@components/spinner.tsx"
import { getCollection } from 'astro:content';

const posts = await getCollection('blog')
---

<Base>
<div class="flex flex-col gap-9 my-9">
    <div class="dragonfly-container flex w-full justify-around">
        <div class="dragonfly   dark:text-zinc-500 text-zinc-600 ">
            <Pfp />
        </div>
        <div class= "about  flex flex-col justify-end h-full dark:border-zinc-700 p-3">
            <h1 class=" border-b my-3 p-1 text-sm border-zinc-300 dark:border-zinc-700"> <span class="text-orange-500">~></span> ABOUT</h1>
            <p class="mt-3 text-sm"> 
            hii there myself Manish, i'm 20 y/o engineering student working around web dev and ml with tons of interests ranging from 
             linux, psychology, space, robotics, f1, history, anime and music. and yes i love cats
             </p>
        </div>
    </div>

    <ol class="list-circle">
        <h1 class="border-t border-b my-3 p-1 text-sm border-zinc-300 dark:border-zinc-700"> <span class="text-orange-500">~></span>  LATEST POSTS</h1>
        {
        posts.map(p => (
        <a href={"blog/" + p.slug}>
            <li class="px-8 grid grid-cols-2 cursor-pointer gap-5">
                <p class="hover:font-bold">{p.data.title}</p>
                <p class="text-end">{p.data.date}</p>
            </li>
        </a>
        ))
        }
    </ol>
</div>
</Base>

<style>
    a {
        width: max-content;
    }

    a:hover {
        font-weight: bold;
    }

.dragonfly-container {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 35vh;
}

.dragonfly {
  flex: 1;
  width:100%;
  text-align: center;
  font-size: 0.5rem;
}

.about {
  flex: 1;
  text-align: left;
  font-size: 1.5rem;
}

@media (max-width: 720px) {
  .dragonfly-container {
    flex-direction: column;
    gap: 5%;
    margin-top: 18%;
    margin-bottom: 18%;
  }}
</style>
